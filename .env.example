# Public key used in client-side map loader (restrict by HTTP referrer in Google Cloud)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_public_browser_key_here

# Place ID can be public but keep it configurable per environment
NEXT_PUBLIC_GOOGLE_PLACE_ID=your_google_place_id_here

# Optional server-side keys for secure API calls in server code
GOOGLE_PLACES_API_KEY=your_server_places_api_key_here
GOOGLE_PLACE_ID=your_google_place_id_here
